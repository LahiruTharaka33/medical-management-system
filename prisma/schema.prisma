generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(uuid())
  name          String
  email         String       @unique
  password      String
  role          String       @default("USER") // 'USER' or 'ADMIN'
  accessGroupId String?
  accessGroup   AccessGroup? @relation(fields: [accessGroupId], references: [id], onDelete: SetNull)
  patients      Patient[]    @relation("CreatedPatients")
}

model AccessGroup {
  id          String    @id @default(uuid())
  groupId     String    @unique
  groupName   String
  description String?
  users       User[]
  patients    Patient[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Patient {
  id            String       @id @default(uuid())
  nic           String       @unique
  firstName     String
  lastName      String
  age           Int
  gender        String
  address       String?
  occupation    String?
  accessGroupId String?
  accessGroup   AccessGroup? @relation(fields: [accessGroupId], references: [id], onDelete: SetNull)
  createdById   String
  createdBy     User         @relation("CreatedPatients", fields: [createdById], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt  
  chronicIllnessProfile ChronicIllnessProfile?
  presentingComplains   PresentingComplain[]
}

model ChronicIllnessProfile {
  id        String   @id @default(uuid())
  patientId String   @unique
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  fbs       Float?   // Fasting Blood Sugar in mg/dL
  hba1c         Float?   // HbA1c in percentage
  bloodPressure    String?  // HTN - Blood Pressure (e.g. 120/80)
  totalCholesterol Float?   // Dyslipidemia - Total Cholesterol in mg/dL
  triglycerides    Float?   // Dyslipidemia - Triglycerides in mg/dL
  hdl              Float?   // Dyslipidemia - HDL in mg/dL
  ldl              Float?   // Dyslipidemia - LDL in mg/dL
  diabetesOnSet    String?
  diabetesIsOnDrugs Boolean @default(false)
  diabetesDrugsText String?
  diabetesSugarControl Boolean @default(false)
  diabetesComplications String?
  htnOnSet         String?
  htnIsOnDrugs     Boolean @default(false)
  htnDrugsText     String?
  dyslipidemiaOnSet String?
  dyslipidemiaIsOnDrugs Boolean @default(false)
  dyslipidemiaDrugsText String?
  diabetesUpdatedAt DateTime?
  htnUpdatedAt      DateTime?
  dyslipidemiaUpdatedAt DateTime?
  dietAndLifestyleText  String?
  dietAndLifestyleUpdatedAt DateTime?
  assessOfComplicationsText String?
  assessOfComplicationsUpdatedAt DateTime?
  otherChronicIllnessesText String?
  otherChronicIllnessesUpdatedAt DateTime?
  updatedAt DateTime @updatedAt
}

model PresentingComplain {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  symptom       String?
  examination   String?
  investigation String?
  diagnose      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
